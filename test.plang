# exitcode;

func factorial(n) {
    if (n == 0) {
        return 1;
    } else {
        let p = n - 1;
        let r = factorial(p);
        return n * r;
    }
}

func fib(n) {
    if (n == 0) {
        return 0;
    } else if (n == 1) {
        return 1;
    } else {
        let a = fib(n - 1);
        let b = fib(n - 2);
        return a + b;
    }
}

func nightmare_math(a, b, c, d) {
    let x =
        (((a + b) * (c + d)) +
        ((a * b) + (c * d)) +
        ((a + c) * (b + d)) +
        ((a * d) + (b * c)) +
        (((a + b + c + d) * (a + b + c + d)) -
        ((a * a) + (b * b) + (c * c) + (d * d))));

    let y =
        (((((x + a) * (x + b)) - (x * c)) +
        ((x * x) + (a * b * c * d))) -
        (((x + a + b) * (x + c + d))));

    return x + y;
}

func branch_storm(v) {
    if (v == 0) {
        return 0;
    } else if (v == 1) {
        return 1;
    } else if (v == 2) {
        return 2;
    } else if (v == 3) {
        return 3;
    } else if (v == 4) {
        return 4;
    } else if (v == 5) {
        return 5;
    } else if (v == 6) {
        return 6;
    } else if (v == 7) {
        return 7;
    } else if (v == 8) {
        return 8;
    } else if (v == 9) {
        return 9;
    } else {
        return v * 2;
    }
}

func loop_stress(limit) {
    let i = 0;
    let sum = 0;

    while (i < limit) {

        let f = factorial(i);
        let fi = fib(i);

        let m = nightmare_math(i, f, fi, limit);

        if (m > 100000) {
            log m;
        } else if (m == 0) {
            log 0;
        } else {
            log m;
        }

        inc sum, m;
        inc i, 1;
    }

    return sum;
}

func chain1(v) { return v + 1; }
func chain2(v) { return chain1(v) + 1; }
func chain3(v) { return chain2(v) + 1; }
func chain4(v) { return chain3(v) + 1; }
func chain5(v) { return chain4(v) + 1; }
func chain6(v) { return chain5(v) + 1; }
func chain7(v) { return chain6(v) + 1; }
func chain8(v) { return chain7(v) + 1; }
func chain9(v) { return chain8(v) + 1; }
func chain10(v) { return chain9(v) + 1; }

func ast_bomb(x) {
    let r =
        (((((((((x + 1) + 2) + 3) + 4) + 5) + 6) + 7) + 8) + 9) +
        (((((((((x * 2) * 3) * 4) * 5) * 6) * 7) * 8) * 9) * 10) +
        (((((((((x - 1) - 2) - 3) - 4) - 5) - 6) - 7) - 8) - 9);

    return r;
}

func main() {

    let base = 6;

    let f = factorial(base);
    let fi = fib(base);

    log f;
    log fi;

    let chaos = nightmare_math(base, f, fi, 9);
    log chaos;

    let branch = branch_storm(base);
    log branch;

    let loop = loop_stress(10);
    log loop;

    let chain = chain10(base);
    log chain;

    let bomb = ast_bomb(base);
    log bomb;

    let mega =
        nightmare_math(
            factorial(5),
            fib(6),
            chain10(3),
            ast_bomb(4)
        );

    log mega;

    if (mega > 1000000) {
        log "massive";
    } else if (mega == 1000000) {
        log "threshold";
    } else {
        log "normal";
    }

    return mega;
}

let result = main();

log result;

exit result;